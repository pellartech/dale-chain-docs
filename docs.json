{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "DALE Chain Documentation",
  "colors": {
    "primary": "#3F5EE7",
    "light": "#3F5EE7",
    "dark": "#3F5EE7"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Join the network",
            "pages": [
              "join-the-network/connect-a-wallet",
              "join-the-network/run-a-node"
            ]
          },
          {
            "group": "Onchain anchoring",
            "pages": [
              "onchain-anchoring/contract",
              "onchain-anchoring/api",
              "onchain-anchoring/sdk",
              "onchain-anchoring/threads",
              "onchain-anchoring/threshold-encrypted-anchors",
              "onchain-anchoring/decryption-nodes"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "#",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Block Explorer",
          "href": "#",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/dale-blockchain-logo-horizontal.svg",
    "dark": "/images/dale-blockchain-logo-horizontal-light.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#100f0f"
    }
  }
}
