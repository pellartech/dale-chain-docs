{
  "openapi": "3.1.0",
  "info": {
    "title": "DALE API",
    "description": "Threaded on-chain anchoring API for DALE.",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://dale-devnet-alb-305857230.ap-southeast-1.elb.amazonaws.com"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Read service readiness"
      }
    },
    "/utils/hash": {
      "post": {
        "summary": "Generate a deterministic SHA-256 hash"
      }
    },
    "/threads/prepare": {
      "post": {
        "summary": "Prepare a signed thread or thread-admin payload"
      }
    },
    "/threads/submit": {
      "post": {
        "summary": "Queue a signed thread or thread-admin chain job"
      }
    },
    "/threads/{threadId}/anchors/prepare": {
      "post": {
        "summary": "Prepare a signed thread anchor payload"
      }
    },
    "/threads/{threadId}/anchors/submit": {
      "post": {
        "summary": "Queue a signed thread anchor chain job"
      }
    },
    "/threads/{threadId}/anchors": {
      "get": {
        "summary": "List indexed anchors for a thread"
      }
    },
    "/jobs/{id}": {
      "get": {
        "summary": "Get chain job status"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  }
}
